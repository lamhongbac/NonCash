@inherits LayoutComponentBase
@inject NonCash.Web.Services.ClientAuthService AuthState

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">NonCash</MudText>
        <MudSpacer />
        @if (AuthState.IsLoggedIn)
        {
            <MudText Typo="Typo.body2" Class="mr-3 mt-1" Color="Color.Primary">@AuthState.FullName (@AuthState.Role)</MudText>
            <MudButton Color="Color.Inherit" Variant="Variant.Text" OnClick="HandleLogout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="mr-1" /> Logout
            </MudButton>
        }
        else
        {
            <MudButton Href="/member-login" Color="Color.Inherit" Variant="Variant.Text">Member Login</MudButton>
            <MudButton Href="/login" Color="Color.Inherit" Variant="Variant.Text">Staff Login</MudButton>
        }
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudDivider Class="my-2" />
            @if (!AuthState.IsLoggedIn)
            {
                <MudText Typo="Typo.caption" Class="px-4">Public</MudText>
                <MudNavLink Href="/member-register" Icon="@Icons.Material.Filled.PersonAdd">Member Registration</MudNavLink>
                <MudNavLink Href="/register" Icon="@Icons.Material.Filled.AppRegistration">Business Registration</MudNavLink>
                <MudDivider Class="my-2" />
            }
            @if (AuthState.IsLoggedIn && AuthState.Role == "Admin")
            {
                <MudText Typo="Typo.caption" Class="px-4">Admin</MudText>
                <MudNavLink Href="/admin/registration-requests" Icon="@Icons.Material.Filled.AppRegistration">Registration Requests</MudNavLink>
                <MudNavLink Href="/admin/brands" Icon="@Icons.Material.Filled.Business">Brands</MudNavLink>
                <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Users</MudNavLink>
                <MudDivider Class="my-2" />
            }
            @if (AuthState.IsLoggedIn && (AuthState.Role == "BrandManager" || AuthState.Role == "Admin"))
            {
                <MudText Typo="Typo.caption" Class="px-4">Brand Manager</MudText>
                <MudNavLink Href="/brandmanager/plans" Icon="@Icons.Material.Filled.Assignment">Voucher Plans</MudNavLink>
                <MudNavLink Href="/brandmanager/outlets" Icon="@Icons.Material.Filled.Store">Outlets</MudNavLink>
                <MudNavLink Href="/brandmanager/customers" Icon="@Icons.Material.Filled.Contacts">Customers</MudNavLink>
                <MudNavLink Href="/pos/redeem" Icon="@Icons.Material.Filled.PointOfSale">POS Redemption</MudNavLink>
                <MudDivider Class="my-2" />
            }
            @if (AuthState.IsLoggedIn && AuthState.IsMember)
            {
                <MudText Typo="Typo.caption" Class="px-4">Member</MudText>
                <MudNavLink Href="/store" Icon="@Icons.Material.Filled.Storefront">Voucher Store</MudNavLink>
                <MudNavLink Href="/my-vouchers" Icon="@Icons.Material.Filled.CardGiftcard">My Vouchers</MudNavLink>
                <MudNavLink Href="/transfers" Icon="@Icons.Material.Filled.SwapHoriz">Transfers</MudNavLink>
                <MudDivider Class="my-2" />
            }
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task HandleLogout()
    {
        await AuthState.LogoutAsync();
    }
}
