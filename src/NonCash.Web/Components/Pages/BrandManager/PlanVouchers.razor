@page "/brandmanager/plans/{PlanId:guid}/vouchers"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject NonCash.Web.Services.ClientAuthService AuthState

<PageTitle>Voucher Details</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Voucher Details</MudText>
    <MudButton Color="Color.Default" Variant="Variant.Text" Href="/brandmanager/plans">
        <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1" /> Back to Plans
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="ma-4" />
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Generate Vouchers</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">Generate voucher details for this approved plan. Each voucher gets a unique serial number and a dynamic security code.</MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
            <MudNumericField T="int" @bind-Value="_quantity" Label="Quantity" Min="1" Max="10000" Adornment="Adornment.End" AdornmentText="vouchers" Style="max-width: 250px;" />
            <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="GenerateVouchers" Disabled="@_generating">
                @if (_generating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Generate
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Batch Promotion (Story 3.1)</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">Distribute vouchers to a target customer list. Paste phone numbers (comma/newline separated) or upload a CSV with phones in the first column. Blacklisted customers are skipped automatically.</MudText>
        <MudStack Spacing="2">
            <MudTextField T="string" @bind-Value="_phoneList" Label="Phone numbers" Lines="4" Variant="Variant.Outlined" Placeholder="0912345678, 0987654321" />
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <InputFile OnChange="OnFileSelected" accept=".csv,.txt" />
                @if (_selectedFile != null)
                {
                    <MudText Typo="Typo.caption">Selected: @_selectedFile.Name</MudText>
                }
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="PromoteVouchers" Disabled="@_promoting" StartIcon="@Icons.Material.Filled.Campaign">
                    @if (_promoting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Distribute Now
                </MudButton>
            </MudStack>
        </MudStack>

        @if (_lastPromoteResult != null)
        {
            <MudAlert Severity="@(_lastPromoteResult.SkippedCount > 0 ? Severity.Warning : Severity.Success)" Class="mt-3">
                Distributed: <b>@_lastPromoteResult.DistributedCount</b> &nbsp;|&nbsp; Skipped: <b>@_lastPromoteResult.SkippedCount</b>
            </MudAlert>
            @if (_lastPromoteResult.SkippedPhones?.Any() == true)
            {
                <MudTable Items="_lastPromoteResult.SkippedPhones" Dense="true" Class="mt-2">
                    <HeaderContent>
                        <MudTh>Phone</MudTh>
                        <MudTh>Reason</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.PhoneNumber</MudTd>
                        <MudTd>@context.Reason</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </MudPaper>

    @if (_vouchers.Any())
    {
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">Generated Vouchers (@_vouchers.Count)</MudText>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="LoadVouchers">
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="mr-1" /> Refresh Codes
                </MudButton>
            </MudStack>
            <MudTable Items="@_vouchers" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Serial No</MudTh>
                    <MudTh>Usage Status</MudTh>
                    <MudTh>Dynamic Code</MudTh>
                    <MudTh>Used Date</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.SerialNo</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="@(context.UsageStatus == "Pending" ? Color.Default : context.UsageStatus == "InUse" ? Color.Info : Color.Success)" Size="Size.Small">
                            @context.UsageStatus
                        </MudChip>
                    </MudTd>
                    <MudTd><MudText Typo="Typo.body2" Style="font-family:monospace; font-size:0.75rem; word-break:break-all;">@context.VoucherCode</MudText></MudTd>
                    <MudTd>@(context.UsedDate.HasValue ? context.UsedDate.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info">No vouchers generated yet for this plan.</MudAlert>
    }
}

@code {
    [Parameter] public Guid PlanId { get; set; }

    private List<VoucherDetailItem> _vouchers = new();
    private bool _loading = true;
    private bool _generating = false;
    private int _quantity = 100;

    // Batch promotion state
    private string _phoneList = string.Empty;
    private IBrowserFile? _selectedFile;
    private bool _promoting = false;
    private PromoteResultDto? _lastPromoteResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadVouchers();
    }

    private async Task LoadVouchers()
    {
        _loading = true;
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Get, $"api/v1/plans/{PlanId}/vouchers");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<List<VoucherDetailItem>>();
                _vouchers = result ?? new();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading vouchers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task GenerateVouchers()
    {
        _generating = true;
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Post, $"api/v1/plans/{PlanId}/generate")
            {
                Content = JsonContent.Create(new { Quantity = _quantity })
            };
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GenerateResult>();
                Snackbar.Add($"Successfully generated {result?.GeneratedCount ?? 0} vouchers!", Severity.Success);
                await LoadVouchers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to generate: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generating = false;
        }
    }

    public class VoucherDetailItem
    {
        public Guid Id { get; set; }
        public string SerialNo { get; set; } = "";
        public string UsageStatus { get; set; } = "";
        public string VoucherCode { get; set; } = "";
        public DateTime? UsedDate { get; set; }
    }

    public class GenerateResult
    {
        public int GeneratedCount { get; set; }
    }

    private void OnFileChanged(IBrowserFile file)
    {
        _selectedFile = file;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
    }

    private async Task PromoteVouchers()
    {
        if (_selectedFile == null && string.IsNullOrWhiteSpace(_phoneList))
        {
            Snackbar.Add("Please paste phone numbers or upload a CSV file.", Severity.Warning);
            return;
        }

        _promoting = true;
        _lastPromoteResult = null;
        try
        {
            var token = await AuthState.GetTokenAsync();
            using var content = new MultipartFormDataContent();

            if (_selectedFile != null)
            {
                var streamContent = new StreamContent(_selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
                streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("text/csv");
                content.Add(streamContent, "file", _selectedFile.Name);
            }

            if (!string.IsNullOrWhiteSpace(_phoneList))
            {
                content.Add(new StringContent(_phoneList), "phoneNumbersCsv");
            }

            var request = new HttpRequestMessage(HttpMethod.Post, $"api/v1/plans/{PlanId}/promote") { Content = content };
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _lastPromoteResult = await response.Content.ReadFromJsonAsync<PromoteResultDto>();
                Snackbar.Add($"Distributed {_lastPromoteResult?.DistributedCount ?? 0} vouchers.", Severity.Success);
                _phoneList = string.Empty;
                _selectedFile = null;
                await LoadVouchers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Promotion failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _promoting = false;
        }
    }

    public class PromoteResultDto
    {
        public int DistributedCount { get; set; }
        public int SkippedCount { get; set; }
        public List<SkippedPhoneDto>? SkippedPhones { get; set; }
    }

    public class SkippedPhoneDto
    {
        public string PhoneNumber { get; set; } = "";
        public string Reason { get; set; } = "";
    }
}
