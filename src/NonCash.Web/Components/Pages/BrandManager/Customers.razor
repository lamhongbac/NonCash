@page "/brandmanager/customers"
@attribute [StreamRendering]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NonCash.Web.Services.ClientAuthService AuthState

<PageTitle>Customer Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Customer Management</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_searchPhone" Label="Phone" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_searchName" Label="Name" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudSelect @bind-Value="_searchStatus" Label="Status" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem Value="@((string?)"Active")">Active</MudSelectItem>
                <MudSelectItem Value="@((string?)"Blacklisted")">Blacklisted</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadCustomers">Search</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreateDialog" Class="ml-2">Add</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="OpenImportDialog" Class="ml-2">Import</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_customers is not null)
{
    <MudTable Items="_customers" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Phone</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Phone">@context.PhoneNumber</MudTd>
            <MudTd DataLabel="Name">@context.FullName</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                @if (context.Status == "Blacklisted")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" OnClick="() => UnblacklistCustomer(context)" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Error" OnClick="() => BlacklistCustomer(context)" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPagination Count="GetPageCount()" Selected="_pageNumber" SelectedChanged="OnPageChanged" Class="mt-4" />
}

<MudDialog @bind-Visible="_showDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "Edit Customer" : "Create Customer")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.PhoneNumber" Label="Phone Number" Required="true" RequiredError="Phone is required" Disabled="_isEdit" />
            <MudTextField @bind-Value="_model.FullName" Label="Full Name" Required="true" RequiredError="Name is required" />
            <MudTextField @bind-Value="_model.Email" Label="Email" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveCustomer">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showImportDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Import Customers from CSV</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4">Upload a CSV file with columns: PhoneNumber, FullName, Email</MudText>
        <InputFile OnChange="LoadFiles" accept=".csv" />
        @if (!string.IsNullOrEmpty(_importFileName))
        {
            <MudText Typo="Typo.caption" Class="mt-2">Selected: @_importFileName</MudText>
        }
        @if (_importResult is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                Created: @_importResult.Created | Updated: @_importResult.Updated | Errors: @_importResult.ErrorCount
            </MudAlert>
            @if (_importResult.Errors.Any())
            {
                <MudList T="string" Dense="true" Class="mt-2">
                    @foreach (var error in _importResult.Errors.Take(10))
                    {
                        <MudListItem T="string" Text="@error" Icon="@Icons.Material.Filled.Error" IconColor="Color.Error" />
                    }
                </MudList>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showImportDialog = false">Close</MudButton>
        <MudButton Color="Color.Primary" OnClick="UploadImport" Disabled="@(_importFile == null)">Upload</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = false;
    private List<CustomerDto>? _customers;
    private int _pageNumber = 1;
    private int _pageSize = 10;
    private int _totalCount = 0;
    private string? _searchPhone;
    private string? _searchName;
    private string? _searchStatus;

    private bool _showDialog = false;
    private bool _isEdit = false;
    private MudForm? _form;
    private CustomerFormModel _model = new();
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true };

    private bool _showImportDialog = false;
    private IBrowserFile? _importFile;
    private string? _importFileName;
    private CustomerImportResultDto? _importResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        _loading = true;
        try
        {
            var query = $"?pageNumber={_pageNumber}&pageSize={_pageSize}";
            if (!string.IsNullOrWhiteSpace(_searchPhone)) query += $"&phoneNumber={Uri.EscapeDataString(_searchPhone)}";
            if (!string.IsNullOrWhiteSpace(_searchName)) query += $"&name={Uri.EscapeDataString(_searchName)}";
            if (!string.IsNullOrWhiteSpace(_searchStatus)) query += $"&status={Uri.EscapeDataString(_searchStatus)}";

            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Get, "api/v1/customers" + query);
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            response.EnsureSuccessStatusCode();
            var result = await response.Content.ReadFromJsonAsync<PagedResult<CustomerDto>>();
            if (result is not null)
            {
                _customers = result.Items.ToList();
                _totalCount = result.TotalCount;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load customers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetPageCount() => (int)Math.Ceiling((double)_totalCount / _pageSize);

    private async Task OnPageChanged(int page)
    {
        _pageNumber = page;
        await LoadCustomers();
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _model = new CustomerFormModel();
        _showDialog = true;
    }

    private void OpenEditDialog(CustomerDto customer)
    {
        _isEdit = true;
        _model = new CustomerFormModel
        {
            Id = customer.Id,
            PhoneNumber = customer.PhoneNumber,
            FullName = customer.FullName,
            Email = customer.Email
        };
        _showDialog = true;
    }

    private void OpenImportDialog()
    {
        _importFile = null;
        _importFileName = null;
        _importResult = null;
        _showImportDialog = true;
    }

    private void LoadFiles(InputFileChangeEventArgs e)
    {
        _importFile = e.File;
        _importFileName = e.File.Name;
    }

    private async Task UploadImport()
    {
        if (_importFile == null) return;

        try
        {
            using var content = new MultipartFormDataContent();
            using var fileStream = _importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("text/csv");
            content.Add(streamContent, "file", _importFile.Name);

            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Post, "api/v1/customers/import") { Content = content };
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _importResult = await response.Content.ReadFromJsonAsync<CustomerImportResultDto>();
                Snackbar.Add("Import completed.", Severity.Success);
                await LoadCustomers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Import failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveCustomer()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            if (_isEdit)
            {
                var request = new { _model.FullName, _model.Email };
                var token = await AuthState.GetTokenAsync();
                var httpRequest = new HttpRequestMessage(HttpMethod.Put, $"api/v1/customers/{_model.Id}") { Content = JsonContent.Create(request) };
                if (!string.IsNullOrEmpty(token))
                    httpRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var response = await Http.SendAsync(httpRequest);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Customer updated successfully.", Severity.Success);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Update failed: {error}", Severity.Error);
                    return;
                }
            }
            else
            {
                var request = new { _model.PhoneNumber, _model.FullName, _model.Email };
                var token = await AuthState.GetTokenAsync();
                var httpRequest = new HttpRequestMessage(HttpMethod.Post, "api/v1/customers") { Content = JsonContent.Create(request) };
                if (!string.IsNullOrEmpty(token))
                    httpRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var response = await Http.SendAsync(httpRequest);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Customer created successfully.", Severity.Success);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Create failed: {error}", Severity.Error);
                    return;
                }
            }

            _showDialog = false;
            await LoadCustomers();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task BlacklistCustomer(CustomerDto customer)
    {
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Put, $"api/v1/customers/{customer.Id}/blacklist");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Customer blacklisted.", Severity.Success);
                await LoadCustomers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Blacklist failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task UnblacklistCustomer(CustomerDto customer)
    {
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Put, $"api/v1/customers/{customer.Id}/unblacklist");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Customer unblacklisted.", Severity.Success);
                await LoadCustomers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Unblacklist failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Blacklisted" => Color.Error,
        _ => Color.Default
    };

    public class CustomerDto
    {
        public Guid Id { get; set; }
        public string PhoneNumber { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    public class PagedResult<T>
    {
        public IReadOnlyList<T> Items { get; set; } = Array.Empty<T>();
        public int TotalCount { get; set; }
        public int PageNumber { get; set; }
        public int PageSize { get; set; }
    }

    public class CustomerFormModel
    {
        public Guid Id { get; set; }
        public string PhoneNumber { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string? Email { get; set; }
    }

    public class CustomerImportResultDto
    {
        public int Created { get; set; }
        public int Updated { get; set; }
        public int ErrorCount { get; set; }
        public List<string> Errors { get; set; } = new();
    }
}
