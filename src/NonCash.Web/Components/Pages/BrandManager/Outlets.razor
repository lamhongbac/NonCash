@page "/brand-manager/outlets"
@attribute [StreamRendering]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Outlet Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Outlet Management</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_searchName" Label="Search by name" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_searchStatus" Label="Status" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem Value="@((string?)"Active")">Active</MudSelectItem>
                <MudSelectItem Value="@((string?)"Closed")">Closed</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="5" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadOutlets">Search</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreateDialog" Class="ml-2">Add Outlet</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_outlets is not null)
{
    <MudTable Items="_outlets" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Address</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>API Key Prefix</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Address">@context.Address</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="API Key Prefix">
                @if (!string.IsNullOrEmpty(context.ApiKeyPrefix))
                {
                    <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.ApiKeyPrefix</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" Disabled="@IsClosed(context.Status)" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Warning" OnClick="() => CloseOutlet(context)" Disabled="@IsClosed(context.Status)" />
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPagination Count="GetPageCount()" Selected="_pageNumber" SelectedChanged="OnPageChanged" Class="mt-4" />
}

<MudDialog @bind-Visible="_showCloseConfirm" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Close Outlet</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to close '@(_outletToClose?.Name)'? This action cannot be undone.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showCloseConfirm = false">Cancel</MudButton>
        <MudButton Color="Color.Warning" OnClick="ConfirmCloseOutlet">Close</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "Edit Outlet" : "Create Outlet")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.Name" Label="Name" Required="true" RequiredError="Name is required" />
            <MudTextField @bind-Value="_model.Address" Label="Address" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveOutlet">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = false;
    private List<OutletDto>? _outlets;
    private int _pageNumber = 1;
    private int _pageSize = 10;
    private int _totalCount = 0;
    private string? _searchName;
    private string? _searchStatus;

    private bool _showDialog = false;
    private bool _isEdit = false;
    private MudForm? _form;
    private OutletFormModel _model = new();
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadOutlets();
    }

    private async Task LoadOutlets()
    {
        _loading = true;
        try
        {
            var query = $"?pageNumber={_pageNumber}&pageSize={_pageSize}";
            if (!string.IsNullOrWhiteSpace(_searchName)) query += $"&name={Uri.EscapeDataString(_searchName)}";
            if (!string.IsNullOrWhiteSpace(_searchStatus)) query += $"&status={Uri.EscapeDataString(_searchStatus)}";

            var result = await Http.GetFromJsonAsync<PagedResult<OutletDto>>("api/v1/outlets" + query);
            if (result is not null)
            {
                _outlets = result.Items.ToList();
                _totalCount = result.TotalCount;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load outlets: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetPageCount() => (int)Math.Ceiling((double)_totalCount / _pageSize);

    private async Task OnPageChanged(int page)
    {
        _pageNumber = page;
        await LoadOutlets();
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _model = new OutletFormModel();
        _showDialog = true;
    }

    private void OpenEditDialog(OutletDto outlet)
    {
        _isEdit = true;
        _model = new OutletFormModel
        {
            Id = outlet.Id,
            Name = outlet.Name,
            Address = outlet.Address
        };
        _showDialog = true;
    }

    private async Task SaveOutlet()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            if (_isEdit)
            {
                var request = new { _model.Name, _model.Address };
                var response = await Http.PutAsJsonAsync($"api/v1/outlets/{_model.Id}", request);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Outlet updated successfully.", Severity.Success);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Update failed: {error}", Severity.Error);
                    return;
                }
            }
            else
            {
                var request = new { _model.Name, _model.Address };
                var response = await Http.PostAsJsonAsync("api/v1/outlets", request);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Outlet created successfully.", Severity.Success);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Create failed: {error}", Severity.Error);
                    return;
                }
            }

            _showDialog = false;
            await LoadOutlets();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private OutletDto? _outletToClose;
    private bool _showCloseConfirm = false;

    private void CloseOutlet(OutletDto outlet)
    {
        _outletToClose = outlet;
        _showCloseConfirm = true;
    }

    private async Task ConfirmCloseOutlet()
    {
        if (_outletToClose == null) return;

        try
        {
            var response = await Http.PutAsync($"api/v1/outlets/{_outletToClose.Id}/close", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Outlet closed successfully.", Severity.Success);
                await LoadOutlets();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Close failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _showCloseConfirm = false;
            _outletToClose = null;
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Closed" => Color.Error,
        _ => Color.Default
    };

    private static bool IsClosed(string status) => status == "Closed";

    public class OutletDto
    {
        public Guid Id { get; set; }
        public Guid BrandId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Address { get; set; }
        public string Status { get; set; } = string.Empty;
        public string? ApiKeyPrefix { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    public class PagedResult<T>
    {
        public IReadOnlyList<T> Items { get; set; } = Array.Empty<T>();
        public int TotalCount { get; set; }
        public int PageNumber { get; set; }
        public int PageSize { get; set; }
    }

    public class OutletFormModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Address { get; set; }
    }
}
