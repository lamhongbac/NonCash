@page "/admin/users"
@attribute [StreamRendering]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NonCash.Web.Services.ClientAuthService AuthState

<PageTitle>User Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">User Management</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="8"></MudItem>
        <MudItem xs="12" sm="4" Class="d-flex justify-end align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreateDialog">Add User</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_users is not null)
{
    <MudTable Items="_users" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Username</MudTh>
            <MudTh>Full Name</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Brand</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Username">@context.Username</MudTd>
            <MudTd DataLabel="Name">@context.FullName</MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Color="@GetRoleColor(context.Role)" Size="Size.Small">@context.Role</MudChip>
            </MudTd>
            <MudTd DataLabel="Brand">@GetBrandName(context.BrandId)</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                @if (context.Status == "Locked")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" OnClick="() => UnlockUser(context)" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" OnClick="() => LockUser(context)" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog @bind-Visible="_showDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "Edit User" : "Create User")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.Username" Label="Username" Required="true" RequiredError="Username is required" Disabled="_isEdit" />
            <MudTextField @bind-Value="_model.Password" Label="@(_isEdit ? "New Password (leave blank to keep current)" : "Password")" Required="@(!_isEdit)" RequiredError="Password is required (min 8 chars)" InputType="InputType.Password" />
            <MudTextField @bind-Value="_model.FullName" Label="Full Name" Required="true" RequiredError="Full name is required" />
            <MudSelect @bind-Value="_model.Role" Label="Role" Required="true">
                <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                <MudSelectItem Value="@("BrandManager")">BrandManager</MudSelectItem>
                <MudSelectItem Value="@("Planner")">Planner</MudSelectItem>
                <MudSelectItem Value="@("Approver")">Approver</MudSelectItem>
            </MudSelect>
            @if (_model.Role != "Admin")
            {
                <MudSelect @bind-Value="_model.BrandId" Label="Brand" Required="true" RequiredError="Brand is required for non-admin roles" Clearable="true">
                    @foreach (var brand in _brands)
                    {
                        <MudSelectItem Value="@((Guid?)brand.Id)">@brand.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveUser">@(_isEdit ? "Save" : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = false;
    private List<UserDto>? _users;
    private List<BrandLookupDto> _brands = new();

    private bool _showDialog = false;
    private bool _isEdit = false;
    private Guid? _editUserId;
    private MudForm? _form;
    private UserFormModel _model = new();
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadBrands();
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Get, "api/v1/users");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<List<UserDto>>();
                if (result is not null) _users = result;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to load users: {response.StatusCode} - {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load users: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadBrands()
    {
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Get, $"api/v1/brands?pageNumber=1&pageSize=1000");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<BrandLookupDto>>();
                if (result is not null) _brands = result.Items.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load brands: {ex.Message}", Severity.Error);
        }
    }

    private string GetBrandName(Guid? brandId)
    {
        if (brandId == null) return "-";
        var brand = _brands.FirstOrDefault(b => b.Id == brandId);
        return brand?.Name ?? brandId.ToString() ?? "-";
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _editUserId = null;
        _model = new UserFormModel();
        _showDialog = true;
    }

    private void OpenEditDialog(UserDto user)
    {
        _isEdit = true;
        _editUserId = user.Id;
        _model = new UserFormModel
        {
            Username = user.Username,
            FullName = user.FullName,
            Role = user.Role,
            BrandId = user.BrandId
        };
        _showDialog = true;
    }

    private async Task SaveUser()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        if (_model.Role != "Admin" && (!_model.BrandId.HasValue || _model.BrandId == Guid.Empty))
        {
            Snackbar.Add("Brand is required for non-admin roles.", Severity.Error);
            return;
        }

        try
        {
            var token = await AuthState.GetTokenAsync();
            HttpResponseMessage response;

            if (_isEdit)
            {
                var request = new { _model.FullName, _model.Role, _model.BrandId, _model.Password };
                var httpRequest = new HttpRequestMessage(HttpMethod.Put, $"api/v1/users/{_editUserId}") { Content = JsonContent.Create(request) };
                if (!string.IsNullOrEmpty(token))
                    httpRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                response = await Http.SendAsync(httpRequest);
            }
            else
            {
                var request = new { _model.Username, _model.Password, _model.FullName, _model.Role, _model.BrandId };
                var httpRequest = new HttpRequestMessage(HttpMethod.Post, "api/v1/users") { Content = JsonContent.Create(request) };
                if (!string.IsNullOrEmpty(token))
                    httpRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                response = await Http.SendAsync(httpRequest);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(_isEdit ? "User updated successfully." : "User created successfully.", Severity.Success);
                _showDialog = false;
                await LoadUsers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"{(_isEdit ? "Update" : "Create")} failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task LockUser(UserDto user)
    {
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Put, $"api/v1/users/{user.Id}/lock");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("User locked.", Severity.Success);
                await LoadUsers();
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task UnlockUser(UserDto user)
    {
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Put, $"api/v1/users/{user.Id}/unlock");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("User unlocked.", Severity.Success);
                await LoadUsers();
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private static Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Error,
        "BrandManager" => Color.Primary,
        "Planner" => Color.Info,
        "Approver" => Color.Success,
        _ => Color.Default
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Locked" => Color.Error,
        _ => Color.Default
    };

    public class UserDto
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public Guid? BrandId { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    public class UserFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Role { get; set; } = "BrandManager";
        public Guid? BrandId { get; set; }
    }

    public class BrandLookupDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    public class PagedResult<T>
    {
        public IReadOnlyList<T> Items { get; set; } = Array.Empty<T>();
        public int TotalCount { get; set; }
        public int PageNumber { get; set; }
        public int PageSize { get; set; }
    }
}
