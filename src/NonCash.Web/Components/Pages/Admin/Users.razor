@page "/admin/users"
@attribute [StreamRendering]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>User Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">User Management</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="8"></MudItem>
        <MudItem xs="12" sm="4" Class="d-flex justify-end align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreateDialog">Add User</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_users is not null)
{
    <MudTable Items="_users" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Username</MudTh>
            <MudTh>Full Name</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Username">@context.Username</MudTd>
            <MudTd DataLabel="Name">@context.FullName</MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Color="@GetRoleColor(context.Role)" Size="Size.Small">@context.Role</MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                @if (context.Status == "Locked")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" OnClick="() => UnlockUser(context)" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" OnClick="() => LockUser(context)" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog @bind-Visible="_showDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Create User</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.Username" Label="Username" Required="true" RequiredError="Username is required" />
            <MudTextField @bind-Value="_model.Password" Label="Password" Required="true" RequiredError="Password is required (min 8 chars)" InputType="InputType.Password" />
            <MudTextField @bind-Value="_model.FullName" Label="Full Name" Required="true" RequiredError="Full name is required" />
            <MudSelect @bind-Value="_model.Role" Label="Role" Required="true">
                <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                <MudSelectItem Value="@("BrandManager")">BrandManager</MudSelectItem>
                <MudSelectItem Value="@("Planner")">Planner</MudSelectItem>
                <MudSelectItem Value="@("Approver")">Approver</MudSelectItem>
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveUser">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = false;
    private List<UserDto>? _users;

    private bool _showDialog = false;
    private MudForm? _form;
    private UserFormModel _model = new();
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<UserDto>>("api/v1/users");
            if (result is not null) _users = result;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load users: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenCreateDialog()
    {
        _model = new UserFormModel();
        _showDialog = true;
    }

    private async Task SaveUser()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            var request = new { _model.Username, _model.Password, _model.FullName, _model.Role, BrandId = (Guid?)null };
            var response = await Http.PostAsJsonAsync("api/v1/users", request);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("User created successfully.", Severity.Success);
                _showDialog = false;
                await LoadUsers();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Create failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task LockUser(UserDto user)
    {
        try
        {
            var response = await Http.PutAsync($"api/v1/users/{user.Id}/lock", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("User locked.", Severity.Success);
                await LoadUsers();
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task UnlockUser(UserDto user)
    {
        try
        {
            var response = await Http.PutAsync($"api/v1/users/{user.Id}/unlock", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("User unlocked.", Severity.Success);
                await LoadUsers();
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private static Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Error,
        "BrandManager" => Color.Primary,
        "Planner" => Color.Info,
        "Approver" => Color.Success,
        _ => Color.Default
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Locked" => Color.Error,
        _ => Color.Default
    };

    public class UserDto
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public Guid? BrandId { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    public class UserFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Role { get; set; } = "BrandManager";
    }
}
