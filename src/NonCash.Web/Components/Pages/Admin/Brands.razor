@page "/admin/brands"
@attribute [StreamRendering]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Brand Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Brand Management</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_searchName" Label="Search by name" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_searchStatus" Label="Status" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem Value="@((string?)"Active")">Active</MudSelectItem>
                <MudSelectItem Value="@((string?)"Suspended")">Suspended</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="5" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadBrands">Search</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreateDialog" Class="ml-2">Add Brand</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_brands is not null)
{
    <MudTable Items="_brands" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Tax Code</MudTh>
            <MudTh>Contact Email</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Tax Code">@context.TaxCode</MudTd>
            <MudTd DataLabel="Contact Email">@context.ContactEmail</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPagination Count="GetPageCount()" Selected="_pageNumber" SelectedChanged="OnPageChanged" Class="mt-4" />
}

<MudDialog @bind-Visible="_showDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "Edit Brand" : "Create Brand")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.Name" Label="Name" Required="true" RequiredError="Name is required" />
            <MudTextField @bind-Value="_model.TaxCode" Label="Tax Code" Required="true" RequiredError="Tax Code is required" Disabled="_isEdit" />
            <MudTextField @bind-Value="_model.ContactEmail" Label="Contact Email" />
            <MudSelect @bind-Value="_model.Status" Label="Status" Required="true">
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Suspended")">Suspended</MudSelectItem>
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveBrand">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = false;
    private List<BrandDto>? _brands;
    private int _pageNumber = 1;
    private int _pageSize = 10;
    private int _totalCount = 0;
    private string? _searchName;
    private string? _searchStatus;

    private bool _showDialog = false;
    private bool _isEdit = false;
    private MudForm? _form;
    private BrandFormModel _model = new();
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadBrands();
    }

    private async Task LoadBrands()
    {
        _loading = true;
        try
        {
            var query = $"?pageNumber={_pageNumber}&pageSize={_pageSize}";
            if (!string.IsNullOrWhiteSpace(_searchName)) query += $"&name={Uri.EscapeDataString(_searchName)}";
            if (!string.IsNullOrWhiteSpace(_searchStatus)) query += $"&status={Uri.EscapeDataString(_searchStatus)}";

            var result = await Http.GetFromJsonAsync<PagedResult<BrandDto>>("api/v1/brands" + query);
            if (result is not null)
            {
                _brands = result.Items.ToList();
                _totalCount = result.TotalCount;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load brands: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetPageCount() => (int)Math.Ceiling((double)_totalCount / _pageSize);

    private async Task OnPageChanged(int page)
    {
        _pageNumber = page;
        await LoadBrands();
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _model = new BrandFormModel();
        _showDialog = true;
    }

    private void OpenEditDialog(BrandDto brand)
    {
        _isEdit = true;
        _model = new BrandFormModel
        {
            Id = brand.Id,
            Name = brand.Name,
            TaxCode = brand.TaxCode,
            ContactEmail = brand.ContactEmail,
            Status = brand.Status
        };
        _showDialog = true;
    }

    private async Task SaveBrand()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid) return;
        }

        try
        {
            if (_isEdit)
            {
                var request = new { _model.Name, _model.ContactEmail, _model.Status };
                var response = await Http.PutAsJsonAsync($"api/v1/brands/{_model.Id}", request);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Brand updated successfully.", Severity.Success);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Update failed: {error}", Severity.Error);
                    return;
                }
            }
            else
            {
                var request = new { _model.Name, _model.TaxCode, _model.ContactEmail };
                var response = await Http.PostAsJsonAsync("api/v1/brands", request);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Brand created successfully.", Severity.Success);
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Create failed: {error}", Severity.Error);
                    return;
                }
            }

            _showDialog = false;
            await LoadBrands();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Suspended" => Color.Warning,
        _ => Color.Default
    };

    public class BrandDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string TaxCode { get; set; } = string.Empty;
        public string? ContactEmail { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    public class PagedResult<T>
    {
        public IReadOnlyList<T> Items { get; set; } = Array.Empty<T>();
        public int TotalCount { get; set; }
        public int PageNumber { get; set; }
        public int PageSize { get; set; }
    }

    public class BrandFormModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string TaxCode { get; set; } = string.Empty;
        public string? ContactEmail { get; set; }
        public string Status { get; set; } = "Active";
    }
}
