@page "/store"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject NonCash.Web.Services.ClientAuthService AuthState

<PageTitle>Voucher Store</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Voucher Store</MudText>
<MudText Typo="Typo.body2" Class="mb-4">Browse and purchase available gift vouchers.</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="ma-4" />
}
else if (!_items.Any())
{
    <MudAlert Severity="Severity.Info">No gift vouchers are currently available for sale.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var item in _items)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <MudCardMedia Image="@item.ImageUrl" Height="160" />
                    }
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@item.FaceValue.ToString("N0") @(item.ValueType == "Percentage" ? "%" : "VND")</MudText>
                        <MudText Typo="Typo.body2">Price: <b>@item.NetValue.ToString("N0") VND</b></MudText>
                        <MudText Typo="Typo.caption">Expires: @item.ExpiryDate.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="() => OpenCheckout(item)">Buy</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<MudDialog @bind-Visible="_showCheckout" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Checkout</MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedItem != null)
        {
            <MudText Typo="Typo.body2" Class="mb-2">FaceValue: <b>@_selectedItem.FaceValue.ToString("N0")</b> | Unit Price: <b>@_selectedItem.NetValue.ToString("N0") VND</b></MudText>
            <MudNumericField T="int" @bind-Value="_quantity" Label="Quantity" Min="1" Max="500" Class="mb-3" />
            <MudTextField T="string" @bind-Value="_invoiceCompany" Label="Invoice Company Name (optional)" Class="mb-3" />
            <MudTextField T="string" @bind-Value="_invoiceTaxCode" Label="Invoice Tax Code (optional)" Class="mb-3" />
            <MudText Typo="Typo.body1">Total: <b>@((_selectedItem.NetValue * _quantity).ToString("N0")) VND</b></MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showCheckout = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="PlaceOrder" Disabled="_submitting">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Place Order
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CatalogItem> _items = new();
    private bool _loading = true;
    private bool _showCheckout;
    private bool _submitting;
    private CatalogItem? _selectedItem;
    private int _quantity = 1;
    private string? _invoiceCompany;
    private string? _invoiceTaxCode;

    private DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalog();
    }

    private async Task LoadCatalog()
    {
        _loading = true;
        try
        {
            var token = await AuthState.GetTokenAsync();
            var request = new HttpRequestMessage(HttpMethod.Get, "api/v1/store/vouchers");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _items = await response.Content.ReadFromJsonAsync<List<CatalogItem>>() ?? new();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading catalog: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCheckout(CatalogItem item)
    {
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token) || !AuthState.IsMember || AuthState.UserId == null || AuthState.UserId == Guid.Empty)
        {
            Snackbar.Add("Please sign in as a member to purchase vouchers.", Severity.Warning);
            Navigation.NavigateTo("/member-login");
            return;
        }

        _selectedItem = item;
        _quantity = 1;
        _invoiceCompany = null;
        _invoiceTaxCode = null;
        _showCheckout = true;
    }

    private async Task PlaceOrder()
    {
        if (_selectedItem == null || !AuthState.IsMember || AuthState.UserId == null || AuthState.UserId == Guid.Empty)
        {
            Snackbar.Add("Member identity is required. Please sign in.", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            var token = await AuthState.GetTokenAsync();
            var body = new
            {
                MemberId = AuthState.UserId.Value,
                PlanId = _selectedItem.PlanId,
                Quantity = _quantity,
                Invoice = (string.IsNullOrWhiteSpace(_invoiceCompany) && string.IsNullOrWhiteSpace(_invoiceTaxCode))
                    ? null
                    : new { CompanyName = _invoiceCompany ?? string.Empty, TaxCode = _invoiceTaxCode ?? string.Empty }
            };
            var request = new HttpRequestMessage(HttpMethod.Post, "api/v1/orders") { Content = JsonContent.Create(body) };
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var order = await response.Content.ReadFromJsonAsync<OrderResponse>();
                if (order == null)
                {
                    Snackbar.Add("Order created but response was empty.", Severity.Error);
                    return;
                }

                // Initiate ZaloPay payment session
                var paymentRequest = new HttpRequestMessage(
                    HttpMethod.Post,
                    $"api/v1/payments/{order.Id}/create")
                {
                    Content = JsonContent.Create(new { returnUrl = (string?)null })
                };
                if (!string.IsNullOrEmpty(token))
                    paymentRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var paymentResponse = await Http.SendAsync(paymentRequest);
                if (paymentResponse.IsSuccessStatusCode)
                {
                    var payment = await paymentResponse.Content.ReadFromJsonAsync<PaymentCreateResponse>();
                    if (!string.IsNullOrWhiteSpace(payment?.PaymentUrl))
                    {
                        Snackbar.Add("Redirecting to ZaloPay...", Severity.Info);
                        Navigation.NavigateTo(payment.PaymentUrl, forceLoad: true);
                        return;
                    }
                }

                var paymentError = await paymentResponse.Content.ReadAsStringAsync();
                Snackbar.Add($"Order created but payment session failed: {paymentError}", Severity.Warning);
                _showCheckout = false;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Order failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    public class CatalogItem
    {
        public Guid PlanId { get; set; }
        public decimal FaceValue { get; set; }
        public decimal NetValue { get; set; }
        public string ValueType { get; set; } = "";
        public DateTime? ValidFrom { get; set; }
        public DateTime? ValidTo { get; set; }
        public DateTime ExpiryDate { get; set; }
        public string? ImageUrl { get; set; }
        public string? IconUrl { get; set; }
    }

    public class OrderResponse
    {
        public Guid Id { get; set; }
        public string Status { get; set; } = "";
        public decimal TotalAmount { get; set; }
    }

    public class PaymentCreateResponse
    {
        public string PaymentUrl { get; set; } = "";
        public Guid TransactionId { get; set; }
        public string GatewayTransactionId { get; set; } = "";
    }
}
